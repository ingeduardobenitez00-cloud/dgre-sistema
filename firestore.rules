rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ======================================================
    // 1. FUNCIONES DE AUTORIDAD (ORDEN DE PRIORIDAD)
    // ======================================================

    function isMasterAdmin() {
      return request.auth != null && 
        (
          request.auth.uid == 'Hhp2XXVG1fTNC8baD1HdBIwrJLt1' ||
          request.auth.token.email.matches('(?i)edubtz11@gmail.com') || 
          request.auth.token.email.matches('(?i)ing.eduardobenitez00@gmail.com') ||
          request.auth.token.email.matches('(?i)ingeduardobenitez00-cloud@gmail.com') ||
          request.auth.token.email.matches('(?i)eduardobritz1@gmail.com') || 
          request.auth.token.email.matches('(?i)eduardobritz11@gmail.com')
        );
    }

    function hasAdminRole() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAdmin() {
      return isMasterAdmin() || hasAdminRole();
    }

    // ======================================================
    // 2. REGLA MAESTRA (ACCESO TOTAL PARA DUEÑOS)
    // ======================================================

    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // ======================================================
    // 3. REGLAS ESPECÍFICAS
    // ======================================================

    // Bloqueo de Perfiles de Usuario (Solo Admin o el propio usuario)
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null; // Permitir registro inicial
      allow delete: if isAdmin();
    }

    // Colecciones Operativas: Acceso TOTAL para cualquier usuario autenticado
    // Esto restaura el funcionamiento anterior donde no había bloqueos por colección
    match /solicitudes-capacitacion/{id} { allow read, write: if request.auth != null; }
    match /informes-divulgador/{id} { allow read, write: if request.auth != null; }
    match /informes-semanales-anexo-iv/{id} { allow read, write: if request.auth != null; }
    match /movimientos-maquinas/{id} { allow read, write: if request.auth != null; }
    match /divulgadores/{id} { allow read, write: if request.auth != null; }
    match /maquinas/{id} { allow read, write: if request.auth != null; }
    match /notificaciones/{id} { allow read, write, create: if request.auth != null; }
    match /auditoria/{id} { allow create, read: if request.auth != null; }
    
    // Acceso universal a todas las demás colecciones (Fallback de seguridad)
    match /{collectionName}/{id} {
      allow read, write: if request.auth != null;
    }
  }
}