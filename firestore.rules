rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ======================================================
    // BYPASS ABSOLUTO - ADMINISTRADOR MAESTRO
    // ======================================================
    // Si el usuario logueado es el dueño, tiene acceso total a TODO.
    // Esta regla es prioritaria y anula cualquier otra restricción.
    match /{document=**} {
      allow read, write: if request.auth != null && (
        request.auth.token.email == 'edubtz11@gmail.com' || 
        request.auth.token.email == 'eduardobritz1@gmail.com' || 
        request.auth.token.email == 'eduardobritz11@gmail.com'
      );
    }

    // ======================================================
    // REGLAS PARA OTROS USUARIOS
    // ======================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      let data = getUserData();
      return data != null && data.role == 'admin';
    }

    /** Gestión de Usuarios **/
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    /** CIDEE - Colecciones **/
    match /solicitudes-capacitacion/{id} {
      allow read, write: if isSignedIn();
    }
    match /informes-divulgador/{id} {
      allow read, write: if isSignedIn();
    }
    match /informes-semanales-anexo-iv/{id} {
      allow read, write: if isSignedIn();
    }
    match /movimientos-maquinas/{id} {
      allow read, write: if isSignedIn();
    }
    match /denuncias-lacres/{id} {
      allow read, write: if isSignedIn();
    }
    match /encuestas-satisfaccion/{id} {
      allow read: if isSignedIn();
      allow create: if true;
    }

    /** Configuración y Geografía **/
    match /datos/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }
    match /partidos-politicos/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }
    match /maquinas/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }
    match /divulgadores/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    /** Auditoría y Presencia **/
    match /auditoria/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && isAdmin();
    }
    match /presencia/{userId} {
      allow read, write: if isSignedIn();
    }
    match /notificaciones/{id} {
      allow read, write: if isSignedIn();
    }

    /** Padrón **/
    match /padron/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }
    
    /** Registros Edilicios **/
    match /reports/{id} {
      allow read, write: if isSignedIn();
    }
    match /imagenes/{id} {
      allow read, write: if isSignedIn();
    }
    match /locales-votacion/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }
    match /informes-semanales-registro/{id} {
      allow read, write: if isSignedIn();
    }
    match /archivos-semanales-registro/{id} {
      allow read, write: if isSignedIn() && isAdmin();
    }
  }
}