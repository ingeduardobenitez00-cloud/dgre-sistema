
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /** 
     * REGLAS DE SEGURIDAD INSTITUCIONAL CIDEE 2026 
     * Blindaje contra accesos no autorizados y auditoría de perfiles.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isActive() {
      let data = getUserData();
      return isSignedIn() && data != null && data.active == true;
    }

    function isAdmin() {
      let data = getUserData();
      return isSignedIn() && data != null && data.role == 'admin';
    }

    function isDirector() {
      let data = getUserData();
      return isSignedIn() && data != null && data.role == 'director';
    }

    /** Gestión de Usuarios - Blindaje de Lista **/
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin() || isDirector();
      allow create: if isAdmin() || (isSignedIn() && request.auth.uid == userId && request.resource.data.role == 'jefe');
      allow update: if (request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    /** Regla para el Padrón Electoral - Solo lectura para personal activo **/
    match /padron/{document=**} {
      allow read: if isActive();
    }

    /** Monitoreo de Presencia **/
    match /presencia/{userId} {
      allow read: if isAdmin() || isDirector();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    /** CIDEE - Colecciones Transaccionales (Acceso restringido a personal activo) **/
    
    match /solicitudes-capacitacion/{solicitudId} {
      allow get: if true; // Habilitado para ciudadanos que completan encuestas
      allow list, create, update: if isActive();
      allow delete: if isAdmin();
    }

    match /encuestas-satisfaccion/{encuestaId} {
      allow read: if isActive();
      allow create: if true; // Público
      allow update: if isActive();
      allow delete: if isAdmin();
    }

    match /anexo-i/{anexoId} {
      allow read, write: if isActive();
    }

    match /informes-divulgador/{informeId} {
      allow read, write: if isActive();
      allow delete: if isAdmin();
    }

    match /informes-semanales-anexo-iv/{informeId} {
      allow read, write: if isActive();
      allow delete: if isAdmin();
    }

    match /movimientos-maquinas/{movimientoId} {
      allow read, write: if isActive();
      allow delete: if isAdmin();
    }

    match /denuncias-lacres/{denunciaId} {
      allow read, write: if isActive();
      allow delete: if isAdmin();
    }

    /** Reglas Generales de Configuración y Geografía **/
    match /datos/{datoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /auditoria/{logId} {
      allow read: if isAdmin() || isDirector();
      allow create: if isSignedIn();
    }

    match /divulgadores/{document=**} {
      allow read: if isActive();
      allow write: if isActive();
    }

    match /maquinas/{maquinaId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    match /locales-votacion/{localId} {
      allow read: if isActive();
      allow write: if isActive();
    }
    
    match /reports/{reportId} {
      allow read, write: if isActive();
    }

    match /imagenes/{imagenId} {
      allow read, write: if isActive();
    }
  }
}
