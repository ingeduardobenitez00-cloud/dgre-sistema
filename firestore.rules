rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for roles
    function isRole(role) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    function isOneOfRoles(roles) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }
    function isSignedIn() {
      return request.auth != null;
    }

    // Rules for /users collection
    match /users/{userId} {
      // Admins can read/write any user document
      allow read, write: if isOneOfRoles(['admin']);
      // Users can create their own profile
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Users can only get, update, delete their own document
      allow get, update, delete: if isSignedIn() && request.auth.uid == userId;
       // Listing users is not allowed for non-admins
      allow list: if isOneOfRoles(['admin']);
    }

    // Rules for /departamentos and its subcollections
    match /departamentos/{document=**} {
        // Admins and Editors can write
        allow write: if isOneOfRoles(['admin', 'editor']);
        // Any signed-in user can read
        allow read: if isSignedIn();
    }

    // Rules for /reports collection
    match /reports/{reportId} {
      // Admins can do anything
      allow read, write: if isOneOfRoles(['admin']);
      // Any signed-in user can create and read reports
      allow create, list, get: if isSignedIn();
    }
    
    // Rules for /datos collection
    match /datos/{datoId} {
      // Any signed-in user can create (import) data
      allow create: if isSignedIn();
      // Only admins and editors can read or delete
      allow read, delete: if isOneOfRoles(['admin', 'editor']);
    }
  }
}
