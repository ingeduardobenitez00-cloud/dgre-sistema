/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset prioritizes strict authorization and assumes that all data
 * requires authentication to access, but will not perform schema validation.
 * This allows for rapid prototyping, while maintaining a secure foundation.
 *
 * Data Structure:
 * - /departamentos/{departamentoId}: Stores department information.
 * - /departamentos/{departamentoId}/distritos/{distritoId}: Stores district information for a specific department.
 * - /departamentos/{departamentoId}/distritos/{distritoId}/imagenes/{imagenId}: Stores image information for a specific district.
 * - /users/{userId}: Stores user profile information.
 * - /reports/{reportId}: Stores detailed report information.
 *
 * Key Security Decisions:
 * - All read and write operations require the user to be signed in.
 * - Listing of departamentos collection is allowed for all signed in users.
 * - User profiles are only accessible to the owner.
 * - Write operations on all collections are denied by default without authentication.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows signed-in users to read department information.
     * @path /departamentos/{departamentoId}
     * @allow (get, list) Signed-in user can read department data.
     * @deny (get, list) Unauthenticated user cannot read department data.
     * @principle Allows public read access to department data for signed-in users.
     */
    match /departamentos/{departamentoId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Allows signed-in users to read district information within a department.
     * @path /departamentos/{departamentoId}/distritos/{distritoId}
     * @allow (get, list) Signed-in user can read district data.
     * @deny (get, list) Unauthenticated user cannot read district data.
     * @principle Allows public read access to district data for signed-in users.
     */
    match /departamentos/{departamentoId}/distritos/{distritoId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Allows signed-in users to read image information within a district.
     * @path /departamentos/{departamentoId}/distritos/{distritoId}/imagenes/{imagenId}
     * @allow (get, list) Signed-in user can read image data.
     * @deny (get, list) Unauthenticated user cannot read image data.
     * @principle Allows public read access to image data for signed-in users.
     */
    match /departamentos/{departamentoId}/distritos/{distritoId}/imagenes/{imagenId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Restricts user profile access to the owner.
     * @path /users/{userId}
     * @allow (get) Owner can read their own profile.
     * @allow (create) Owner can create their own profile.
     * @allow (update, delete) Owner can update/delete their own profile.
     * @deny (get, create, update, delete) Non-owner cannot access the profile.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows signed-in users to read reports.
     * @path /reports/{reportId}
     * @allow (get, list) Signed-in user can read report data.
     * @deny (get, list) Unauthenticated user cannot read report data.
     * @principle Allows public read access to report data for signed-in users.
     */
    match /reports/{reportId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    // --- Helper Functions ---

    /**
     * @description Checks if the user is signed in.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the owner of the document.
     * @param {string} userId The user ID to check against.
     * @return {bool} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the owner of the existing document.
     * @param {string} userId The user ID to check against.
     * @return {bool} True if the user is the owner and the document exists.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}