rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ======================================================
    // 1. BYPASS MAESTRO - PRIORIDAD ABSOLUTA
    // ======================================================
    // Acceso TOTAL e INCONDICIONAL para los administradores maestros.
    // Esto ignora cualquier otra regla y garantiza el control total.
    match /{document=**} {
      allow read, write: if request.auth != null && (
        request.auth.token.email.lower() == 'edubtz11@gmail.com' || 
        request.auth.token.email.lower() == 'eduardobritz1@gmail.com' || 
        request.auth.token.email.lower() == 'eduardobritz11@gmail.com'
      );
    }

    // ======================================================
    // 2. FUNCIONES DE APOYO
    // ======================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return request.auth.token.email.lower() in [
        'edubtz11@gmail.com', 
        'eduardobritz1@gmail.com', 
        'eduardobritz11@gmail.com'
      ];
    }

    function isAdmin() {
      if (isMasterAdmin()) {
        return true;
      }
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) && get(path).data.role == 'admin';
    }

    // ======================================================
    // 3. REGLAS POR COLECCIÓN
    // ======================================================

    match /users/{userId} {
      // El admin maestro SIEMPRE puede crear, borrar o editar cualquier usuario.
      allow read, write: if isMasterAdmin();
      
      // Reglas estándar para otros usuarios
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /solicitudes-capacitacion/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /informes-divulgador/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /informes-semanales-anexo-iv/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /movimientos-maquinas/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /denuncias-lacres/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /encuestas-satisfaccion/{id} {
      allow read: if isSignedIn();
      allow create: if true;
    }

    match /datos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /partidos-politicos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /maquinas/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /divulgadores/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /auditoria/{id} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }
    
    match /presencia/{userId} {
      allow read, write: if isSignedIn();
    }
    
    match /notificaciones/{id} {
      allow read, write: if isSignedIn();
    }

    match /padron/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /reports/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /imagenes/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /locales-votacion/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /informes-semanales-registro/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /archivos-semanales-registro/{id} {
      allow read, write: if isAdmin();
    }
    
    match /anexo-i/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /config/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}