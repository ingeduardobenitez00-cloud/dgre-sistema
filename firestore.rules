rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Check user role from their profile in /users collection
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isRole(role) {
      return isSignedIn() && getUserData(request.auth.uid).role == role;
    }

    function isOneOfRoles(roles) {
      return isSignedIn() && getUserData(request.auth.uid).role in roles;
    }

    // --- Collection Rules ---

    // /users/{userId}
    match /users/{userId} {
      // Admins can manage any user profile
      allow read, write: if isRole('admin');

      // Any authenticated user can create their own profile
      allow create: if isSignedIn() && request.auth.uid == userId;

      // Users can only read and update their own profile
      allow get, update: if isSignedIn() && request.auth.uid == userId;
      
      // Prevent listing all users for security
      allow list: if false;
    }

    // /departamentos and subcollections (distritos, imagenes)
    match /departamentos/{docId=**} {
        // Any authenticated user can read departments, districts and images
        allow get, list: if isSignedIn();
        
        // Only admins and editors can create, update, or delete
        allow write: if isOneOfRoles(['admin', 'editor']);
    }

    // /reports/{reportId}
    match /reports/{reportId} {
        // Any authenticated user can create and read reports
        allow get, list, create: if isSignedIn();

        // Only admins can update or delete reports
        allow update, delete: if isRole('admin');
    }
  }
}
